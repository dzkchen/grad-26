# Next.js / Auth.js
NEXTAUTH_SECRET=
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=
NEXTAUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
ADMIN_EMAILS=

# Postgres (Supabase)
DATABASE_URL_POOLED=
DATABASE_URL_DIRECT=

# Cloudflare R2
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=
R2_BUCKET=
R2_PUBLIC_HOSTNAME=

# Go API (Next.js -> Cloud Run)
# Local dev: http://localhost:8080
# Production: paste the Cloud Run URL (the *.run.app one) from `gcloud run services describe ... --format='value(status.url)'`
GO_API_URL=
# Shared HMAC secret. Must match the value set on Cloud Run.
# Generate with: openssl rand -hex 32
INTERNAL_API_SECRET=
